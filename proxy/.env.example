# ── Staxx Proxy Gateway — Environment Variables ─────────────────────
# Copy this file to .env and fill in the values.

# Server
STAXX_PROXY_HOST=0.0.0.0
STAXX_PROXY_PORT=8080
STAXX_PROXY_DEBUG=true
STAXX_PROXY_LOG_LEVEL=DEBUG

# Provider Base URLs
STAXX_PROXY_OPENAI_BASE_URL=https://api.openai.com
STAXX_PROXY_ANTHROPIC_BASE_URL=https://api.anthropic.com

# Redis (telemetry stream + Celery broker)
STAXX_PROXY_REDIS_URL=redis://localhost:6379/0
STAXX_PROXY_TELEMETRY_STREAM=staxx:telemetry
STAXX_PROXY_TELEMETRY_MAXLEN=100000

# Postgres (API key validation)
STAXX_PROXY_DATABASE_URL=postgresql://staxx:staxx@localhost:5432/staxx
STAXX_PROXY_DB_POOL_MIN=2
STAXX_PROXY_DB_POOL_MAX=10

# Telemetry fallback (used when Redis is down)
STAXX_PROXY_TELEMETRY_FALLBACK_PATH=/tmp/staxx_telemetry_fallback.jsonl

# Timeouts (seconds)
STAXX_PROXY_FORWARD_TIMEOUT=120.0
STAXX_PROXY_FORWARD_CONNECT_TIMEOUT=10.0

# CORS (comma-separated origins)
STAXX_PROXY_CORS_ORIGINS=["*"]
