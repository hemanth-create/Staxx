# ============================================================================
# Staxx Intelligence — Development Environment Configuration
# ============================================================================
# Copy this to .env and fill in actual values. This file is checked into git.
# NEVER commit .env or secrets to the repository.
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL 16 + TimescaleDB)
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_USER=staxx
POSTGRES_PASSWORD=staxx_dev_password
POSTGRES_DB=staxx
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# Redis (Celery broker, streams, caching)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# Authentication & Authorization
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─────────────────────────────────────────────────────────────────────────────
# Stripe Integration (Billing & Subscriptions)
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_GROWTH=price_growth_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# ─────────────────────────────────────────────────────────────────────────────
# MinIO / S3 Compatible Storage
# ─────────────────────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_NAME=staxx-outputs

# ─────────────────────────────────────────────────────────────────────────────
# Application URLs
# ─────────────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# Proxy Gateway Configuration (STAXX_PROXY_ prefix)
# ─────────────────────────────────────────────────────────────────────────────
STAXX_PROXY_HOST=0.0.0.0
STAXX_PROXY_PORT=8080
STAXX_PROXY_DEBUG=false
STAXX_PROXY_REDIS_URL=redis://localhost:6379/0
STAXX_PROXY_DATABASE_URL=postgresql://staxx:staxx_dev_password@localhost:5432/staxx
STAXX_PROXY_OPENAI_BASE_URL=https://api.openai.com
STAXX_PROXY_ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─────────────────────────────────────────────────────────────────────────────
# Telemetry & Logging
# ─────────────────────────────────────────────────────────────────────────────
# STAXX_PROXY_LOG_LEVEL=DEBUG
# STAXX_PROXY_TELEMETRY_STREAM=staxx:telemetry
